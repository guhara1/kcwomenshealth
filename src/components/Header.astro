---
import { SITE } from "../lib/site";
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="brand" aria-label={SITE.name + " 홈"}>
      <span class="brand__mark">VIP</span>
      <span>{SITE.name}</span>
    </a>

    <nav class="nav" aria-label="주요 메뉴">
      <a href="/area/seoul/">서울</a>
      <a href="/area/gyeonggi/">경기</a>
      <a href="/area/incheon/">인천</a>
      <a href="/area/busan/">부산</a>
      <a href="/station/">지하철역</a>
      <a href="/program/">프로그램</a>
      <a href="/reservation/">예약 안내</a>
    </nav>

    <a class="header-call" href={SITE.phoneHref}>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.69 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.33 1.85.56 2.81.69A2 2 0 0 1 22 16.92z"></path></svg>
      {SITE.phone}
    </a>
  </div>
</header>
