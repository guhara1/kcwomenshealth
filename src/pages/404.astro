---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="페이지를 찾을 수 없습니다 (404)"
  description="요청하신 페이지를 찾을 수 없습니다. 지역 또는 지하철역 안내로 이동하세요."
  noindex={true}
>
  <section class="section text-center" style="padding-block:88px">
    <div class="container container--narrow">
      <h1 style="font-size:3rem">404</h1>
      <p class="section__lead">요청하신 페이지를 찾을 수 없습니다.</p>
      <div class="hero__cta" style="justify-content:center;margin-top:24px">
        <a class="btn btn--cta" href="/">홈으로</a>
        <a class="btn btn--blue" href="/area/">지역으로 찾기</a>
        <a class="btn btn--outline" href="/station/">역으로 찾기</a>
      </div>
    </div>
  </section>
</BaseLayout>
