---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { SITE } from "../../lib/site";
import { services } from "../../lib/data";
import { breadcrumbSchema, faqSchema, absoluteUrl } from "../../lib/seo";

export function getStaticPaths() {
  return services.map((sv) => ({ params: { service: sv.slug }, props: { sv } }));
}

const { sv } = Astro.props;
const path = `/service/${sv.slug}/`;
const others = services.filter((x) => x.slug !== sv.slug);

const title = `${sv.name}｜${SITE.name} 출장마사지·홈타이`;
const description = sv.summary;

const faq = [
  {
    q: `${sv.shortName} 관리는 어떻게 예약하나요?`,
    a: `전화예약 ${SITE.phone}로 방문 위치와 가능 주소, 희망 시간을 알려주시면 안내드립니다.`,
  },
];

const schema = [
  breadcrumbSchema([
    { name: "홈", path: "/" },
    { name: "서비스 안내", path: "/service/chuljang/" },
    { name: sv.name, path },
  ]),
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: sv.name,
    serviceType: sv.focus,
    description: sv.summary,
    provider: { "@id": absoluteUrl("/#business") },
    areaServed: ["서울", "경기", "인천", "부산"],
    url: absoluteUrl(path),
  },
  faqSchema(faq),
];
---

<BaseLayout title={title} description={description} path={path} schema={schema}>
  <Breadcrumbs
    items={[
      { name: "홈", path: "/" },
      { name: "서비스 안내", path: "/service/chuljang/" },
      { name: sv.name },
    ]}
  />
  <section class="section" style="padding-top:8px">
    <div class="container prose">
      <span class="eyebrow">서비스 안내</span>
      <h1>{sv.name}</h1>
      <p>{sv.summary}</p>

      <h2>{sv.shortName} 관리 기준</h2>
      <p>{sv.focus}을 중심으로 안내합니다.</p>
      <ul>
        {sv.points.map((p) => <li>{p}</li>)}
      </ul>

      <div class="notice">
        <div class="notice__title">예약 전 확인</div>
        <p style="margin:0">
          방문 위치(<a href="/service/home/">자택</a> ·
          <a href="/service/hotel/">호텔·숙소</a> ·
          <a href="/service/officetel/">오피스텔</a>)에 따라 출입·주소 확인
          기준이 다릅니다. <a href="/guide/before-use/">이용 전 확인사항</a>과
          <a href="/reservation/">예약 안내</a>를 함께 확인하세요.
        </p>
      </div>

      <h2>다른 서비스 안내</h2>
      <div class="chip-list">
        {
          others.map((o) => (
            <a class="chip" href={`/service/${o.slug}/`}>{o.shortName}</a>
          ))
        }
      </div>

      <div class="notice notice--warn">
        <div class="notice__title">예약 안내</div>
        <p style="margin:0">
          전화예약 <a href={SITE.phoneHref}>{SITE.phone}</a> 로 문의해 주세요.
          본 안내는 관리 방식과 예약 기준 중심이며, 불법·선정적 서비스는 제공하지
          않습니다.
        </p>
      </div>

      <h2>자주 묻는 질문</h2>
      <div class="faq">
        {
          faq.map((f) => (
            <details>
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
