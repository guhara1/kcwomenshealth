---
import BaseLayout from "../layouts/BaseLayout.astro";
import PriceTable from "../components/PriceTable.astro";
import ProgramLinks from "../components/ProgramLinks.astro";
import { SITE } from "../lib/site";
import { sidos, services, prioritySigungus, stationsByGroup } from "../lib/data";
import { breadcrumbSchema, faqSchema } from "../lib/seo";

const title =
  "서울·경기·인천·부산 출장마사지｜지역별·지하철역별 홈타이 안내";
const description =
  "서울·경기·인천·부산 출장마사지·홈타이 지역과 지하철역 생활권을 확인하세요.";

const faq = [
  {
    q: "출장마사지와 홈타이는 어떻게 예약하나요?",
    a: "전화예약 0508-202-4719로 위치(자택·호텔·오피스텔)와 방문 가능 주소, 희망 시간을 알려주시면 방문 가능 지역과 추가 이동비 기준을 안내드립니다.",
  },
  {
    q: "어느 지역까지 방문이 가능한가요?",
    a: "서울 전역과 경기 주요 도시, 인천, 부산 도시철도 생활권을 중심으로 안내합니다. 지역 페이지와 지하철역 페이지에서 방문 가능 생활권을 확인할 수 있습니다.",
  },
  {
    q: "추가 이동비는 어떻게 확인하나요?",
    a: "지역과 시간대, 거리 조건에 따라 추가 이동비가 발생할 수 있습니다. 예약 전 전화로 정확한 기준을 안내받으실 수 있습니다.",
  },
];

const schema = [
  breadcrumbSchema([{ name: "홈", path: "/" }]),
  faqSchema(faq),
];

const lifeAreas = sidos.flatMap((s) =>
  s.lifeAreas.slice(0, 3).map((l) => ({ label: l, sido: s.regionSlug }))
);
---

<BaseLayout title={title} description={description} path="/" schema={schema}>
  <!-- HERO -->
  <section class="hero">
    <div class="container hero__inner">
      <span class="hero__badge"><span class="dot"></span> Premium Massage</span>
      <h1>
        <span class="kw">서울·경기·인천·부산 지역별·지하철역별 안내</span>
        출장마사지<br />24시간 홈타이
      </h1>
      <p class="hero__sub">
        서울, 경기, 인천, 부산 주요 지역과 지하철역 생활권을 기준으로 방문 가능
        지역과 예약 전 확인사항을 안내합니다.
      </p>
      <ul class="hero__points">
        <li>어디든 30분 내 방문</li>
        <li>근육·디스크 케어 전문</li>
        <li>연중무휴 24시간 예약</li>
      </ul>
      <div class="hero__cta">
        <a class="btn btn--cta" href={SITE.phoneHref}>전화예약 {SITE.phone}</a>
        <a class="btn btn--line" href="/area/">지역으로 찾기</a>
        <a class="btn btn--line" href="/station/">역으로 찾기</a>
      </div>
      <div class="hero__stats">
        <div><b>4</b><span>서울·경기·인천·부산</span></div>
        <div><b>78+</b><span>지하철역 생활권</span></div>
        <div><b>24h</b><span>연중무휴 예약</span></div>
      </div>
    </div>
  </section>

  <!-- 4대 권역 -->
  <section class="section">
    <div class="container">
      <div class="section__head">
        <span class="eyebrow">지역으로 찾기</span>
        <h2 class="section__title">서울·경기·인천·부산 지역 찾기</h2>
        <p class="section__lead">
          권역을 선택하면 구·시·군과 대표 역세권 생활권 안내로 이동합니다.
        </p>
      </div>
      <div class="grid grid--4">
        {
          sidos.map((s) => (
            <a class="card" href={`/area/${s.regionSlug}/`}>
              <div class="card__title">
                {s.regionName} <span class="arrow">→</span>
              </div>
              <p class="card__desc">{s.contentFocus}</p>
              <div class="card__tags">
                {s.nearbyStations.slice(0, 3).map((st) => (
                  <span class="tag">{st}</span>
                ))}
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 지하철역으로 찾기 -->
  <section class="section section--soft">
    <div class="container">
      <div class="section__head">
        <span class="eyebrow">가까운 역으로 찾기</span>
        <h2 class="section__title">지하철역으로 찾기</h2>
        <p class="section__lead">
          현재 위치에서 가까운 지하철역을 기준으로 방문 가능 생활권을
          확인하세요.
        </p>
      </div>
      <div class="grid grid--4">
        {
          sidos.map((s) => {
            const sts = stationsByGroup(s.regionSlug).slice(0, 6);
            return (
              <div class="card">
                <div class="card__title">{s.regionName} 지하철역</div>
                <div class="chip-list" style="margin-top:12px">
                  {sts.map((st) => (
                    <a class="chip chip--soft" href={`/station/${st.stationGroup}/${st.stationSlug}/`}>
                      {st.stationName}
                    </a>
                  ))}
                </div>
                <a href={`/station/${s.regionSlug}/`} style="margin-top:14px;font-weight:700;font-size:0.875rem">
                  {s.regionName} 역 전체 보기 →
                </a>
              </div>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- 요금표 (메인 + 모든 지역 페이지 공통) -->
  <PriceTable />

  <!-- 인기 생활권 -->
  <section class="section">
    <div class="container">
      <div class="section__head">
        <span class="eyebrow">인기 생활권</span>
        <h2 class="section__title">자주 찾는 생활권</h2>
      </div>
      <div class="chip-list">
        {
          lifeAreas.map((l) => (
            <a class="chip" href={`/area/${l.sido}/`}>{l.label}</a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 서비스 안내 -->
  <section class="section section--soft">
    <div class="container">
      <div class="section__head">
        <span class="eyebrow">서비스 안내</span>
        <h2 class="section__title">출장마사지·홈타이 이용 안내</h2>
      </div>
      <div class="grid grid--4">
        {
          services.slice(0, 8).map((sv) => (
            <a class="card" href={`/service/${sv.slug}/`}>
              <div class="card__title">{sv.shortName}</div>
              <p class="card__desc">{sv.summary}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 마사지 프로그램 내부링크 -->
  <section class="section">
    <div class="container">
      <ProgramLinks
        limit={20}
        title="마사지 프로그램으로 찾기"
        lead="스웨디시·타이·아로마테라피·발마사지 등 관리 종류별 안내를 확인하세요."
      />
    </div>
  </section>

  <!-- 본문 (SEO 롱폼) -->
  <section class="section">
    <div class="container prose">
      <h2>서울·경기·인천·부산에서 출장마사지를 찾을 때 확인할 기준</h2>
      <p>
        서울, 경기, 인천, 부산 출장마사지를 찾는 분들은 보통 현재 있는 지역명이나
        가까운 지하철역을 기준으로 검색합니다. 어떤 분은 <a href="/area/seoul/">강남</a>처럼
        지역명으로 찾고, 어떤 분은 <a href="/station/seoul/gangnam-station/">강남역</a>처럼
        역 이름으로 찾습니다. 경기에서는 <a href="/station/gyeonggi/suwon-station/">수원역</a>,
        <a href="/station/gyeonggi/pangyo-station/">판교역</a>, 정자역처럼 도시와 역이 함께
        검색되고, 인천은 <a href="/station/incheon/bupyeong-station/">부평역</a>, 송도, 청라
        생활권이 중요합니다. 부산은 <a href="/station/busan/seomyeon-station/">서면역</a>,
        해운대, 센텀시티처럼 도시철도 기반 검색 의도가 강합니다.
      </p>

      <h2>지역 페이지와 지하철역 페이지를 나누는 이유</h2>
      <p>
        이 사이트는 서울·경기·인천·부산을 하나의 큰 안내 허브로 묶되, 각 권역의
        구조를 다르게 설계합니다. 구·시 페이지는 그 지역 전체의 생활권을
        설명하고, 역 페이지는 역 주변 생활권과 인접 행정동을 설명합니다. 같은
        본문에서 지역명이나 역명만 바꾸지 않고, 각 페이지가 서로 다른 역할을
        하도록 작성합니다.
      </p>

      <h2>서울 주요 생활권 안내</h2>
      <p>
        서울은 25개 구 단위 안내를 먼저 제공하고, 강남·역삼, 잠실·송파,
        홍대·합정, 여의도·영등포, 신림·관악 같은 핵심 역세권을 함께 연결합니다.
        자세한 내용은 <a href="/area/seoul/">서울 지역 안내</a>와
        <a href="/station/seoul/">서울 지하철역 안내</a>에서 확인하세요.
      </p>
      <div class="chip-list">
        {
          prioritySigungus("seoul").slice(0, 8).map((g) => (
            <a class="chip" href={`/area/seoul/${g.regionSlug}/`}>{g.regionName}</a>
          ))
        }
      </div>

      <h2>경기 주요 도시와 역세권 안내</h2>
      <p>
        경기는 수원·성남·고양·용인·부천처럼 시 단위 안내를 중심으로,
        수원역·판교역·정자역 같은 핵심 역세권을 함께 다룹니다.
        <a href="/area/gyeonggi/">경기 지역 안내</a>에서 도시별 생활권을 확인할 수
        있습니다.
      </p>
      <div class="chip-list">
        {
          prioritySigungus("gyeonggi").slice(0, 8).map((g) => (
            <a class="chip" href={`/area/gyeonggi/${g.regionSlug}/`}>{g.regionName}</a>
          ))
        }
      </div>

      <h2>인천 주요 구·군과 역세권 안내</h2>
      <p>
        인천은 부평·남동·연수·서구 같은 구 단위와 인천1·2호선, 공항철도 생활권을
        함께 다룹니다. <a href="/area/incheon/">인천 지역 안내</a>에서 부평, 송도,
        구월동, 검단, 청라 생활권을 확인하세요.
      </p>

      <h2>부산 주요 구·군과 도시철도 생활권 안내</h2>
      <p>
        부산은 16개 구·군과 부산 도시철도 주요 역을 연결합니다. 서면·전포,
        해운대·중동, 센텀시티·우동, 광안리·수영 생활권을
        <a href="/area/busan/">부산 지역 안내</a>에서 살펴볼 수 있습니다.
      </p>

      <h2>자택·숙소·오피스텔 이용 전 확인사항</h2>
      <p>
        <a href="/service/home/">자택</a>, <a href="/service/hotel/">호텔·숙소</a>,
        <a href="/service/officetel/">오피스텔</a> 등 방문 위치에 따라 출입 방법과
        주소 확인 기준이 다릅니다. 예약 전에 방문 가능 주소, 동·호수, 공동현관
        출입 방법을 미리 확인하면 방문이 원활합니다. 자세한 내용은
        <a href="/guide/before-use/">이용 전 확인사항</a>을 참고하세요.
      </p>

      <h2>지역·역 페이지 중복 방지 운영 기준</h2>
      <p>
        가장 중요한 운영 원칙은 지역명·역명만 바꾼 페이지를 대량으로 만들지 않는
        것입니다. 환승역이라도 노선별·출구별로 페이지를 쪼개지 않고, 역명 기준으로
        하나의 안내 페이지만 제공합니다. 콘텐츠가 충분히 준비된 지역과 역부터
        단계적으로 안내를 확장합니다.
      </p>

      <h2>예약 문의 전 확인할 정보</h2>
      <p>
        예약 전에는 방문 위치, 희망 시간, 방문 가능 주소, 추가 이동비 기준을
        확인합니다. 전화예약 <a href={SITE.phoneHref}>{SITE.phone}</a>로
        문의하시면 빠르게 안내드립니다. 본 사이트는 정보형 안내
        페이지이며, 불법·선정적 서비스는 제공하지 않습니다.
      </p>

      <div class="hero__cta" style="margin-top:24px">
        <a class="btn btn--cta" href={SITE.phoneHref}>전화예약 {SITE.phone}</a>
        <a class="btn btn--outline" href="/reservation/">예약 안내 보기</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--soft">
    <div class="container container--narrow">
      <div class="section__head">
        <span class="eyebrow">자주 묻는 질문</span>
        <h2 class="section__title">예약 전 자주 묻는 질문</h2>
      </div>
      <div class="faq">
        {
          faq.map((f) => (
            <details>
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
