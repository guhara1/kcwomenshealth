---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import PriceTable from "../../components/PriceTable.astro";
import { SITE } from "../../lib/site";
import { programs, getProgram } from "../../lib/data";
import { breadcrumbSchema, faqSchema, absoluteUrl } from "../../lib/seo";

export function getStaticPaths() {
  return programs.map((p) => ({ params: { slug: p.slug }, props: { p } }));
}

const { p } = Astro.props;
const path = `/program/${p.slug}/`;
const others = programs.filter((x) => x.slug !== p.slug);
const otherChips = others.slice(0, 12);
const related = others.slice(0, 3);
const kw = p.keywords ?? [];

const title = `${p.name}｜${p.shortName} 출장마사지·홈타이 안내`;
const description = p.summary;

const schema = [
  breadcrumbSchema([
    { name: "홈", path: "/" },
    { name: "프로그램", path: "/program/" },
    { name: p.shortName, path },
  ]),
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: p.name,
    serviceType: `${p.shortName} 방문 관리`,
    description: p.summary,
    provider: { "@id": absoluteUrl("/#business") },
    areaServed: ["서울", "경기", "인천", "부산"],
    url: absoluteUrl(path),
  },
  faqSchema(p.faq),
];
---

<BaseLayout title={title} description={description} path={path} schema={schema}>
  <Breadcrumbs
    items={[
      { name: "홈", path: "/" },
      { name: "프로그램", path: "/program/" },
      { name: p.shortName },
    ]}
  />

  <section class="section" style="padding:8px 0 0">
    <div class="container prose">
      <span class="eyebrow">마사지 프로그램</span>
      <h1>{p.name} · {p.shortName} 출장마사지 홈타이 안내</h1>

      <h2>{p.shortName}란?</h2>
      <p>{p.p1}</p>

      <h2>{p.shortName}의 특징과 이용 안내</h2>
      <p>{p.p2}</p>
      <p>
        {p.shortName}는 {kw.slice(0, 3).join(", ")} 등 다양한 검색으로 찾는 분들이
        많습니다. {SITE.name}는 자택·호텔·오피스텔 등 방문 위치에 맞춰 {p.shortName}
        관리를 안내하며, 같은 프로그램이라도 관리 시간(60·90·120분)과 강도 요청에
        따라 구성이 달라질 수 있습니다. 처음 이용하신다면 희망 부위와 강도를 미리
        알려 주시면 보다 편안하게 받으실 수 있습니다.
      </p>
    </div>
  </section>

  <PriceTable areaLabel={p.shortName} />

  <section class="section">
    <div class="container prose">
      <h2>출장·홈케어로 받는 {p.shortName} 진행 방식</h2>
      <p>{p.p3}</p>
      <p>
        {SITE.name}는 서울·경기·인천·부산 전 지역에서 {p.shortName} 방문 관리를
        안내합니다. <a href="/area/seoul/">서울 {p.shortName}</a>,
        <a href="/area/gyeonggi/">경기 {p.shortName}</a>,
        <a href="/area/incheon/">인천 {p.shortName}</a>,
        <a href="/area/busan/">부산 {p.shortName}</a> 지역 안내와
        <a href="/station/">지하철역</a> · <a href="/life/">생활권</a> 페이지에서
        가까운 위치를 확인할 수 있습니다.
      </p>
      <p>
        {p.shortName}와 함께 살펴보면 좋은 관리로는
        {related.map((r, i) => (
          <>
            {i > 0 ? ", " : " "}
            <a href={`/program/${r.slug}/`}>{r.shortName}</a>
          </>
        ))} 등이 있습니다. 방문 위치와 시간대에 따라 두 가지 이상을 함께
        구성하기도 하므로, 예약 시 원하는 조합을 말씀해 주시면 안내해 드립니다.
      </p>

      <h2>{p.shortName} 예약 전 확인사항</h2>
      <p>{p.p4}</p>
      <ul>
        <li>방문 가능 주소 확인 (자택·호텔·오피스텔 동·호수)</li>
        <li>희망 시간과 관리 강도·요청사항 확인</li>
        <li>추가 이동비 여부 확인</li>
        <li>불법·선정적 서비스 불가 안내</li>
      </ul>
      <table class="info-table">
        <tbody>
          <tr><th>상호</th><td>{SITE.name}</td></tr>
          <tr><th>전화예약</th><td><a href={SITE.phoneHref}>{SITE.phone}</a></td></tr>
          <tr><th>운영시간</th><td>{SITE.hours}</td></tr>
          <tr><th>안내 지역</th><td>서울 · 경기 · 인천 · 부산</td></tr>
          <tr><th>기본 요금</th><td>60분 90,000원 · 90분 150,000원 · 120분 180,000원</td></tr>
        </tbody>
      </table>

      <h2>다른 마사지 프로그램</h2>
      <div class="chip-list">
        {
          otherChips.map((o) => (
            <a class="chip chip--soft" href={`/program/${o.slug}/`}>{o.shortName}</a>
          ))
        }
      </div>

      <div class="notice notice--warn">
        <div class="notice__title">예약 안내</div>
        <p style="margin:0">
          {p.shortName} 예약은 전화 <a href={SITE.phoneHref}>{SITE.phone}</a> 로
          문의해 주세요. 본 안내는 관리 방식 정보형이며 불법·선정적 서비스는
          제공하지 않습니다.
        </p>
      </div>

      <h2>{p.shortName} 자주 묻는 질문</h2>
      <div class="faq">
        {
          p.faq.map((f) => (
            <details>
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
