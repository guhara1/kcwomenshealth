---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import { SITE, TELEGRAM, sidoName } from "../../../lib/site";
import {
  stations,
  getSido,
  getSigungu,
  nearbyStationsOf,
  isIndexable,
} from "../../../lib/data";
import {
  breadcrumbSchema,
  faqSchema,
  serviceAreaSchema,
} from "../../../lib/seo";

export function getStaticPaths() {
  return stations.map((st) => ({
    params: { group: st.stationGroup, station: st.stationSlug },
    props: { st },
  }));
}

const { st } = Astro.props;
const path = `/station/${st.stationGroup}/${st.stationSlug}/`;
const noindex = !isIndexable(st.contentStatus);
const sido = getSido(st.stationGroup);
const sigungu = getSigungu(st.stationGroup, st.sigunguSlug);
const neighbors = nearbyStationsOf(st, 5);

const title = `${st.stationName} 출장마사지｜${st.nearbyAreas
  .slice(0, 2)
  .join("·")} 인접 생활권 홈타이 안내`;
const description = `${st.stationName} 출장마사지 예약 전 ${st.nearbyAreas
  .slice(0, 3)
  .join("·")} 주변 생활권을 확인하세요.`;

const faq = [
  {
    q: `${st.stationName} 주변 출장마사지·홈타이는 어떻게 예약하나요?`,
    a: `전화예약 ${SITE.phone} 또는 텔레그램으로 ${st.stationName} 인근 방문 위치와 가능 주소, 희망 시간을 알려주시면 방문 가능 생활권과 추가 이동비 기준을 안내드립니다.`,
  },
  {
    q: `${st.stationName}은 환승역인데 페이지가 하나인가요?`,
    a: `네. 환승역이라도 노선별·출구별로 페이지를 나누지 않고 역명 기준으로 하나의 안내 페이지를 제공합니다. ${
      st.transferYn ? st.transferLines.join(", ") + " 환승 정보를 함께 안내합니다." : ""
    }`,
  },
];

const schema = noindex
  ? []
  : [
      breadcrumbSchema([
        { name: "홈", path: "/" },
        { name: "지하철역 안내", path: "/station/" },
        { name: `${sido?.regionName} 역`, path: `/station/${st.stationGroup}/` },
        { name: st.stationName, path },
      ]),
      serviceAreaSchema(`${st.stationName} 인근 출장마사지·홈타이`, path),
      faqSchema(faq),
    ];
---

<BaseLayout
  title={title}
  description={description}
  path={path}
  noindex={noindex}
  schema={schema}
>
  <Breadcrumbs
    items={[
      { name: "홈", path: "/" },
      { name: "지하철역 안내", path: "/station/" },
      { name: `${sido?.regionName} 역`, path: `/station/${st.stationGroup}/` },
      { name: st.stationName },
    ]}
  />

  <section class="section" style="padding-top:8px">
    <div class="container prose">
      <span class="eyebrow">{sidoName(st.stationGroup)} · {st.sigungu}</span>
      <h1>{st.stationName} 출장마사지 · 역 주변 홈타이 예약 안내</h1>

      <h2>{st.stationName} 주변에서 출장마사지를 찾을 때 확인할 기준</h2>
      <p>
        {st.stationName} 주변에서 출장마사지와 홈타이를 찾을 때는 {st.contentFocus}
        을 함께 확인하면 좋습니다. {st.nearbyAreas.slice(0, 3).join(", ")} 등 인접
        행정동을 기준으로 방문 가능 지역과 동선을 확인할 수 있습니다.
        {
          st.transferYn &&
            ` ${st.stationName}은 ${st.transferLines.join(", ")}이 지나는 환승역이지만, 안내 페이지는 역명 기준 하나로 제공합니다.`
        }
      </p>

      <h2>{st.stationName} 인근 생활권 안내</h2>
      <p>{st.stationName} 주변의 대표 생활권과 인접 행정동은 다음과 같습니다.</p>
      <ul>
        {st.nearbyAreas.map((a) => <li>{a}</li>)}
      </ul>

      <h2>{st.stationName} 주변 방문 가능 지역</h2>
      <p>
        역 주변 상권과 주거지, 숙소·오피스텔 분포에 따라 방문 가능 지역이
        달라집니다. 예약 시 정확한 주소와 출입 방법을 확인하면 방문이 원활합니다.
      </p>
      <table class="info-table">
        <tbody>
          <tr><th>역명</th><td>{st.stationName}</td></tr>
          <tr><th>소재 지역</th><td>
            {
              sigungu ? (
                <a href={`/area/${st.stationGroup}/${st.sigunguSlug}/`}>{st.sido} {st.sigungu}</a>
              ) : (
                `${st.sido} ${st.sigungu}`
              )
            }
          </td></tr>
          <tr><th>노선</th><td>{st.transferLines.join(", ")}</td></tr>
          <tr><th>주소</th><td>{st.address}</td></tr>
          <tr><th>전화예약</th><td><a href={SITE.phoneHref}>{SITE.phone}</a></td></tr>
        </tbody>
      </table>

      <h2>주변 지역과 가까운 역 안내</h2>
      <p>{sido?.regionName}의 인접 역도 함께 확인해 보세요.</p>
      <div class="chip-list">
        {
          neighbors.map((n) => (
            <a class="chip" href={`/station/${n.stationGroup}/${n.stationSlug}/`}>{n.stationName}</a>
          ))
        }
        {
          sigungu && (
            <a class="chip chip--soft" href={`/area/${st.stationGroup}/${st.sigunguSlug}/`}>
              {st.sigungu} 지역 안내
            </a>
          )
        }
      </div>

      <h2>자택·숙소·오피스텔 이용 전 확인사항</h2>
      <p>
        <a href="/service/home/">자택</a>, <a href="/service/hotel/">호텔·숙소</a>,
        <a href="/service/officetel/">오피스텔</a> 등 방문 위치에 따라 주소·출입
        확인 기준이 다릅니다. 예약 전 <a href="/guide/before-use/">이용 전
        확인사항</a>을 확인하세요.
      </p>

      <h2>추가 이동비 확인 기준</h2>
      <p>
        {st.stationName} 인근이라도 지역·시간대·거리에 따라 추가 이동비가 발생할
        수 있습니다. 예약 전 텔레그램 또는 전화로 정확한 기준을 확인하실 수
        있습니다.
      </p>

      <h2>{st.stationName} 페이지 중복 방지 운영 기준</h2>
      <p>
        역 페이지는 역 주변 생활권을 설명하고, 구·시 페이지는 지역 전체를
        설명하도록 역할을 나눕니다. 출구별·노선별 페이지를 만들지 않으며, 인접
        역과 지역을 내부링크로 연결합니다.
      </p>

      <div class="notice notice--warn">
        <div class="notice__title">예약 안내</div>
        <p style="margin:0">
          전화예약 <a href={SITE.phoneHref}>{SITE.phone}</a> · 텔레그램
          <a href={TELEGRAM.reservation} target="_blank" rel="noopener nofollow">문의하기</a>.
          불법·선정적 서비스는 제공하지 않습니다.
        </p>
      </div>

      <h2>{st.stationName} 자주 묻는 질문</h2>
      <div class="faq">
        {
          faq.map((f) => (
            <details>
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
