---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { SITE } from "../lib/site";
import { breadcrumbSchema, faqSchema } from "../lib/seo";

const path = "/reservation/";
const title = "예약 안내｜출장마사지·홈타이 예약 전 확인 정보";
const description =
  "출장마사지·홈타이 예약 전 위치·시간·주소·추가 이동비 확인 방법을 안내합니다.";

const faq = [
  {
    q: "예약은 어떻게 진행되나요?",
    a: `전화예약 ${SITE.phone}로 방문 위치(자택·호텔·오피스텔), 방문 가능 주소, 희망 시간을 알려주시면 방문 가능 지역과 추가 이동비 기준을 안내드립니다.`,
  },
  {
    q: "예약을 변경하거나 취소할 수 있나요?",
    a: "예약 변경이나 취소는 방문 예정 시간 전에 미리 연락 주시면 안내드립니다.",
  },
];

const schema = [
  breadcrumbSchema([
    { name: "홈", path: "/" },
    { name: "예약 안내", path },
  ]),
  faqSchema(faq),
];
---

<BaseLayout title={title} description={description} path={path} schema={schema}>
  <Breadcrumbs items={[{ name: "홈", path: "/" }, { name: "예약 안내" }]} />
  <section class="section" style="padding-top:8px">
    <div class="container prose">
      <span class="eyebrow">예약 안내</span>
      <h1>예약 안내 · 문의 전 확인할 정보</h1>
      <p>
        출장마사지와 홈타이는 방문형 관리이므로, 예약 전에 몇 가지 정보를 미리
        확인하면 방문이 원활합니다. 아래 순서로 안내드립니다.
      </p>

      <h2>예약 절차</h2>
      <ol>
        <li>방문 위치를 확인합니다 — 자택 · 호텔/숙소 · 오피스텔</li>
        <li>방문 가능 주소(동·호수, 공동현관 출입 방법)를 확인합니다.</li>
        <li>희망 시간과 관리 종류를 알려 주십니다.</li>
        <li>방문 가능 지역과 추가 이동비 기준을 안내받습니다.</li>
        <li>예약을 확정합니다.</li>
      </ol>

      <table class="info-table">
        <tbody>
          <tr><th>상호</th><td>{SITE.name}</td></tr>
          <tr><th>전화예약</th><td><a href={SITE.phoneHref}>{SITE.phone}</a></td></tr>
          <tr><th>운영시간</th><td>{SITE.hours}</td></tr>
          <tr><th>안내 지역</th><td>서울 · 경기 · 인천 · 부산</td></tr>
        </tbody>
      </table>

      <div class="notice notice--warn">
        <div class="notice__title">안내</div>
        <p style="margin:0">
          본 사이트는 정보형 안내 페이지입니다. 허위 후기, 선정적 표현, 불법
          서비스는 제공하지 않습니다. 예약 전
          <a href="/guide/before-use/">이용 전 확인사항</a>을 확인하세요.
        </p>
      </div>

      <div class="hero__cta" style="margin-top:8px">
        <a class="btn btn--cta" href={SITE.phoneHref}>전화예약 {SITE.phone}</a>
      </div>

      <h2>자주 묻는 질문</h2>
      <div class="faq">
        {
          faq.map((f) => (
            <details>
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
