---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { SITE } from "../../lib/site";
import { breadcrumbSchema, faqSchema } from "../../lib/seo";

const path = "/guide/before-use/";
const title = "이용 전 확인사항｜방문형 관리 예약 전 안내";
const description =
  "출장마사지·홈타이 이용 전 방문 가능 지역, 주소·출입, 추가 이동비 확인사항 안내.";

const faq = [
  {
    q: "방문 전 무엇을 준비하면 되나요?",
    a: "정확한 주소와 출입 방법(공동현관·객실 호수), 방문 가능 시간을 미리 확인해 두시면 방문이 원활합니다.",
  },
];

const schema = [
  breadcrumbSchema([
    { name: "홈", path: "/" },
    { name: "이용 전 확인사항", path },
  ]),
  faqSchema(faq),
];
---

<BaseLayout title={title} description={description} path={path} schema={schema}>
  <Breadcrumbs items={[{ name: "홈", path: "/" }, { name: "이용 전 확인사항" }]} />
  <section class="section" style="padding-top:8px">
    <div class="container prose">
      <span class="eyebrow">이용 전 확인사항</span>
      <h1>이용 전 확인사항</h1>
      <p>
        방문형 관리는 예약 전 확인이 중요합니다. 아래 항목을 미리 확인하시면
        방문과 예약이 원활합니다.
      </p>

      <h2>방문 가능 지역 확인</h2>
      <p>
        서울·경기·인천·부산 지역과 가까운 지하철역을 기준으로 방문 가능 생활권을
        안내합니다. <a href="/area/">지역 안내</a> 또는
        <a href="/station/">지하철역 안내</a>에서 확인하세요.
      </p>

      <h2>주소·출입 확인</h2>
      <ul>
        <li><a href="/service/home/">자택</a> — 상세 주소와 출입 동선</li>
        <li><a href="/service/hotel/">호텔·숙소</a> — 숙소명, 객실 호수, 프런트 출입 규정</li>
        <li><a href="/service/officetel/">오피스텔</a> — 동·호수, 공동현관 출입 방법, 주차</li>
      </ul>

      <h2>예약 가능 시간·추가 이동비</h2>
      <p>
        지역·시간대·거리에 따라 예약 가능 시간과 추가 이동비가 달라질 수
        있습니다. 예약 시 정확한 기준을 안내받으실 수 있습니다.
      </p>

      <div class="notice notice--warn">
        <div class="notice__title">불법·선정적 서비스 불가 안내</div>
        <p style="margin:0">
          본 사이트는 합법적인 방문형 관리 안내만 제공합니다. 불법·선정적
          서비스는 제공하지 않으며, 허위 후기나 과장 문구를 사용하지 않습니다.
          개인정보는 <a href="/privacy/">개인정보 처리방침</a>에 따라 처리됩니다.
        </p>
      </div>

      <h2>자주 묻는 질문</h2>
      <div class="faq">
        {
          faq.map((f) => (
            <details>
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))
        }
      </div>

      <p class="muted" style="margin-top:24px">
        예약 문의: <a href={SITE.phoneHref}>{SITE.phone}</a>
      </p>
    </div>
  </section>
</BaseLayout>
