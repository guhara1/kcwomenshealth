---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../../../components/Breadcrumbs.astro";
import LocalNav from "../../../../components/LocalNav.astro";
import PriceTable from "../../../../components/PriceTable.astro";
import { SITE, TELEGRAM, sidoName } from "../../../../lib/site";
import {
  allDetailDongs,
  getSido,
  getSigungu,
  dongsOf,
  hasDongDetail,
  stations,
} from "../../../../lib/data";
import {
  breadcrumbSchema,
  faqSchema,
  serviceAreaSchema,
} from "../../../../lib/seo";

export function getStaticPaths() {
  return allDetailDongs().map((e) => ({
    params: { sido: e.sidoSlug, gu: e.guSlug, dong: e.dong.slug },
    props: e,
  }));
}

const { sidoSlug, guSlug, dong, detail } = Astro.props;
const sido = getSido(sidoSlug)!;
const gu = getSigungu(sidoSlug, guSlug)!;
const guPath = `/area/${sidoSlug}/${guSlug}/`;
const path = `${guPath}${dong.slug}/`;

// 인접 역 → 역 페이지(있으면) 링크
const stationLink = (name: string) => {
  const st = stations.find((s) => s.stationName === name);
  return st ? `/station/${st.stationGroup}/${st.stationSlug}/` : null;
};
// 인접 동 → 같은 구 내 상세 페이지(있으면) 링크
const guDongs = dongsOf(sidoSlug, guSlug);
const adjLink = (name: string) => {
  const d = guDongs.find((x) => x.name === name);
  return d && hasDongDetail(sidoSlug, guSlug, d.slug)
    ? `/area/${sidoSlug}/${guSlug}/${d.slug}/`
    : null;
};

// 안전 접근(빈 배열 폴백)
const lm = detail.landmarks.length ? detail.landmarks : [`${dong.name} 일대`];
const adj = detail.adjacentAreas.length ? detail.adjacentAreas : [gu.regionName];
const sts = detail.nearbyStations.length ? detail.nearbyStations : ["인근 역"];

const title = `${dong.name} 출장마사지｜${
  detail.landmarks[0] ?? detail.nearbyStations[0] ?? gu.regionName
} 생활권 홈타이 안내`;
const description = `${dong.name} 출장마사지 예약 전 ${detail.adjacentAreas
  .slice(0, 3)
  .join("·")} 인접 생활권을 확인하세요.`;

const faq = [
  {
    q: `${dong.name} 출장마사지·홈타이는 어떻게 예약하나요?`,
    a: `전화예약 ${SITE.phone} 또는 텔레그램으로 ${dong.name} 내 방문 위치와 가능 주소, 희망 시간을 알려주시면 ${detail.nearbyStations.join(", ")} 인근 방문 가능 생활권과 추가 이동비 기준을 안내드립니다.`,
  },
  {
    q: `${dong.name}은 ${gu.regionName} 어느 생활권에 속하나요?`,
    a: `${dong.name}은 ${detail.character} 성격으로, ${detail.adjacentAreas.join(", ")} 등과 인접해 있습니다. 방문 동선은 ${detail.nearbyStations[0]} 기준으로 확인하면 편리합니다.`,
  },
];

const schema = [
  breadcrumbSchema([
    { name: "홈", path: "/" },
    { name: "지역 안내", path: "/area/" },
    { name: sido.regionName, path: `/area/${sidoSlug}/` },
    { name: gu.regionName, path: guPath },
    { name: dong.name, path },
  ]),
  serviceAreaSchema(`${dong.name} 출장마사지·홈타이`, path),
  faqSchema(faq),
];
---

<BaseLayout title={title} description={description} path={path} schema={schema}>
  <LocalNav homeLabel={gu.regionName} homeHref={guPath} showLife={false} />
  <Breadcrumbs
    items={[
      { name: "홈", path: "/" },
      { name: "지역 안내", path: "/area/" },
      { name: sido.regionName, path: `/area/${sidoSlug}/` },
      { name: gu.regionName, path: guPath },
      { name: dong.name },
    ]}
  />

  <section class="section" style="padding:8px 0 0">
    <div class="container prose">
      <span class="eyebrow">{sidoName(sidoSlug)} {gu.regionName} · {dong.name}</span>
      <h1>{dong.name} 출장마사지 · {dong.name} 홈타이 예약 안내</h1>
      <p class="hero__sub" style="color:var(--text-soft)">
        {detail.character} {dong.name}의 방문 가능 생활권과 예약 전 확인사항을
        안내합니다. {detail.adjacentAreas.join(", ")} 인접 지역도 함께 확인하세요.
      </p>
      <div class="hero__cta" style="margin-top:18px">
        <a class="btn btn--cta" href={SITE.phoneHref}>전화예약 {SITE.phone}</a>
        <a class="btn btn--blue" href={TELEGRAM.reservation} target="_blank" rel="noopener nofollow">문자 문의</a>
        <a class="btn btn--outline" href={guPath}>{gu.regionName} 전체</a>
      </div>

      <h2>{dong.name} 생활권 소개</h2>
      <p>{detail.p1}</p>
      <p>
        {dong.name}은 {lm.join(", ")} 일대를 중심으로 {detail.character} 생활권을
        형성합니다. {gu.regionName} 안에서도 {dong.name}은 상권과 주거지가 만나는
        위치라, 방문 가능 지역과 동선을 함께 확인하면 예약이 수월합니다.
        {sts.join(", ")} 등 가까운 역과 {adj.join(", ")} 인접 지역을 함께
        고려하는 방식을 권장합니다.
      </p>
      {
        detail.landmarks.length > 0 && (
          <div class="chip-list" style="margin:8px 0 4px">
            {detail.landmarks.map((l) => (
              <span class="chip chip--soft">{l}</span>
            ))}
          </div>
        )
      }
    </div>
  </section>

  <!-- 요금표 (메인 + 모든 지역 페이지 공통) -->
  <PriceTable areaLabel={dong.name} />

  <section class="section">
    <div class="container prose">
      <h2>{dong.name} 주변 상권·주거 환경</h2>
      <p>
        {dong.name} 일대는 {detail.character} 특성이 뚜렷해, 오피스텔·아파트·숙소가
        혼재한 구간과 주거 전용 구간의 방문 조건이 다릅니다. {lm[0]} 인근은
        상업·업무 수요가 많고, {adj[0]} 방향 주거 구간은 야간·주말 방문 가능 여부
        확인이 중요합니다. 같은 {dong.name}이라도 위치에 따라 방문 가능 시간과
        동선을 개별적으로 확인하는 방식을 권장합니다.
      </p>

      <h2>{dong.name} 주변 방문 가능 지역</h2>
      <p>{detail.p2}</p>
      <p>
        {sts.map((s) => `${s} 인근`).join(", ")}을 기준으로 접근할 수 있으며,
        {adj.join(", ")} 방향으로 이동하는 경우 거리와 시간대에 따라 추가 이동비
        기준이 달라질 수 있습니다. 예약 시 {dong.name} 내 정확한 방문 주소를
        먼저 확인하면 방문 동선을 안내받기 쉽습니다.
      </p>

      <h3>{dong.name} 인근 지하철역</h3>
      <p>{dong.name}과 가까운 지하철역을 기준으로 방문 동선을 확인할 수 있습니다.</p>
      <div class="chip-list">
        {
          detail.nearbyStations.map((name) => {
            const href = stationLink(name);
            return href ? (
              <a class="chip" href={href}>{name}</a>
            ) : (
              <span class="chip chip--soft">{name}</span>
            );
          })
        }
      </div>

      <h3>{dong.name} 인접 지역</h3>
      <div class="chip-list">
        {
          detail.adjacentAreas.map((name) => {
            const href = adjLink(name);
            return href ? (
              <a class="chip" href={href}>{name}</a>
            ) : (
              <span class="chip chip--soft">{name}</span>
            );
          })
        }
        <a class="chip" href={guPath}>{gu.regionName} 전체</a>
      </div>

      <h2>{dong.name} 예약 전 확인사항</h2>
      <p>{detail.p3}</p>
      <p>
        {dong.name} 방문 예약은 전화 {SITE.phone} 또는 텔레그램으로 받으며,
        {sts[0]} 기준 방문 동선과 {adj[0]} 인접 지역 이동 여부를 함께 확인하면
        예약이 빠릅니다. {gu.regionName} {dong.name}은 {detail.character} 특성을
        고려해 방문 가능 시간과 추가 이동비 기준을 예약 시 안내합니다.
      </p>
      <ul>
        <li>방문 가능 주소 확인 (자택·호텔·오피스텔 동·호수)</li>
        <li>건물 출입 방식(공동현관·프런트) 확인</li>
        <li>예약 가능 시간과 추가 이동비 여부 확인</li>
        <li>결제 방식·예약 변경 기준 확인</li>
        <li>개인정보 처리 기준 확인 / 불법·선정적 서비스 불가 안내</li>
      </ul>

      <table class="info-table">
        <tbody>
          <tr><th>상호</th><td>{SITE.name}</td></tr>
          <tr><th>전화예약</th><td><a href={SITE.phoneHref}>{SITE.phone}</a></td></tr>
          <tr><th>안내 지역</th><td>{gu.regionName} {dong.name} 및 인접 생활권</td></tr>
          <tr><th>기본 요금</th><td>60분 90,000원 · 90분 150,000원 · 120분 180,000원</td></tr>
          <tr><th>추가 이동비</th><td>지역·시간대·거리에 따라 예약 시 안내</td></tr>
        </tbody>
      </table>

      <div class="notice notice--warn">
        <div class="notice__title">예약 안내</div>
        <p style="margin:0">
          전화예약 <a href={SITE.phoneHref}>{SITE.phone}</a> · 텔레그램
          <a href={TELEGRAM.reservation} target="_blank" rel="noopener nofollow">문의하기</a>.
          {dong.name} 안내는 정보형이며 허위 후기·선정적 표현을 사용하지 않습니다.
        </p>
      </div>

      <h2>{dong.name} 페이지 중복 방지 운영 기준</h2>
      <p>
        {dong.name} 페이지는 동 단위 생활권을 설명하고, {gu.regionName} 페이지는
        구 전체를, 역 페이지는 역 주변을 설명하도록 역할을 나눕니다. {dong.name}은
        {detail.landmarks.length ? ` ${detail.landmarks.join(", ")} 등 ` : " "}실제
        생활권 특성을 중심으로 작성해 같은 본문 반복을 피합니다.
      </p>

      <h2>{dong.name} 자주 묻는 질문</h2>
      <div class="faq">
        {
          faq.map((f) => (
            <details>
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
