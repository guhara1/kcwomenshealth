---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import { SITE, TELEGRAM, sidoName } from "../../../lib/site";
import {
  sigungus,
  getSido,
  sigungusBySido,
  stations,
  isIndexable,
} from "../../../lib/data";
import {
  breadcrumbSchema,
  faqSchema,
  serviceAreaSchema,
} from "../../../lib/seo";

export function getStaticPaths() {
  return sigungus.map((g) => ({
    params: { sido: g.parentSlug, gu: g.regionSlug },
    props: { g },
  }));
}

const { g } = Astro.props;
const sido = getSido(g.parentSlug)!;
const path = `/area/${g.parentSlug}/${g.regionSlug}/`;
const noindex = !isIndexable(g.contentStatus);

// 인접 지역(같은 권역 내 다른 구·시) — 본문 내부링크용
const neighbors = sigungusBySido(g.parentSlug)
  .filter((x) => x.regionSlug !== g.regionSlug)
  .slice(0, 8);

// 이 지역에 매칭되는 역 페이지(있으면 링크)
const linkedStations = stations.filter((st) => st.sigunguSlug === g.regionSlug);
// 데이터에 등록된 nearbyStations 중 실제 페이지가 있는 것
const stationByName = (name: string) =>
  stations.find((st) => st.stationName === name);

const title = `${g.regionName} 출장마사지｜${g.nearbyAreas
  .slice(0, 2)
  .join("·")} 생활권 홈타이 안내`;
const description = `${g.regionName} 출장마사지 예약 전 ${g.nearbyAreas
  .slice(0, 3)
  .join("·")} 인접 생활권을 확인하세요.`;

const faq = [
  {
    q: `${g.regionName} 출장마사지·홈타이는 어떻게 예약하나요?`,
    a: `전화예약 ${SITE.phone} 또는 텔레그램으로 ${g.regionName} 내 방문 위치와 가능 주소, 희망 시간을 알려주시면 방문 가능 생활권과 추가 이동비 기준을 안내드립니다.`,
  },
  {
    q: `${g.regionName} 추가 이동비 기준이 궁금합니다.`,
    a: `지역과 시간대, 거리에 따라 추가 이동비가 발생할 수 있습니다. 예약 전 텔레그램 또는 전화로 정확한 기준을 확인하실 수 있습니다.`,
  },
];

const schema = noindex
  ? []
  : [
      breadcrumbSchema([
        { name: "홈", path: "/" },
        { name: "지역 안내", path: "/area/" },
        { name: sido.regionName, path: `/area/${g.parentSlug}/` },
        { name: g.regionName, path },
      ]),
      serviceAreaSchema(`${g.regionName} 출장마사지·홈타이`, path),
      faqSchema(faq),
    ];
---

<BaseLayout
  title={title}
  description={description}
  path={path}
  noindex={noindex}
  schema={schema}
>
  <Breadcrumbs
    items={[
      { name: "홈", path: "/" },
      { name: "지역 안내", path: "/area/" },
      { name: sido.regionName, path: `/area/${g.parentSlug}/` },
      { name: g.regionName },
    ]}
  />

  <section class="section" style="padding-top:8px">
    <div class="container prose">
      <span class="eyebrow">{sidoName(g.parentSlug)} · {g.regionName}</span>
      <h1>{g.regionName} 출장마사지 · 지역별 홈타이 예약 안내</h1>

      <h2>{g.regionName}에서 출장마사지를 찾을 때 확인할 기준</h2>
      <p>
        {g.regionName}에서 출장마사지와 홈타이를 찾을 때는 {g.contentFocus} 점을
        함께 확인하면 좋습니다. {g.nearbyAreas.slice(0, 3).join(", ")} 등 대표
        생활권을 기준으로 방문 가능 지역과 가까운 지하철역을 확인할 수 있습니다.
        방문 위치(자택·호텔·오피스텔)에 따라 예약 가능 시간과 추가 이동비 기준이
        달라질 수 있습니다.
      </p>

      <h2>{g.regionName} 주요 생활권 안내</h2>
      <p>
        {g.regionName}의 대표 생활권은 다음과 같습니다. 각 생활권은 주거지와
        상권, 숙소·오피스텔 분포가 달라 방문 가능 지역 확인 기준도 조금씩
        다릅니다.
      </p>
      <ul>
        {g.nearbyAreas.map((a) => <li>{a}</li>)}
      </ul>

      <h2>대표동·역세권별 방문 가능 지역</h2>
      <p>
        {g.regionName}과 가까운 지하철역을 기준으로 생활권을 확인하면 방문 동선을
        잡기 쉽습니다. 아래 역의 주변 생활권 안내를 함께 참고하세요.
      </p>
      <div class="chip-list">
        {
          g.nearbyStations.map((name) => {
            const st = stationByName(name);
            return st ? (
              <a class="chip" href={`/station/${st.stationGroup}/${st.stationSlug}/`}>{name}</a>
            ) : (
              <span class="chip chip--soft">{name}</span>
            );
          })
        }
        {
          linkedStations
            .filter((st) => !g.nearbyStations.includes(st.stationName))
            .map((st) => (
              <a class="chip" href={`/station/${st.stationGroup}/${st.stationSlug}/`}>{st.stationName}</a>
            ))
        }
      </div>

      <h2>자택·숙소·오피스텔 이용 전 확인사항</h2>
      <p>
        방문 위치에 따라 출입 방법이 다릅니다.
        <a href="/service/home/">자택</a>은 상세 주소와 출입 동선,
        <a href="/service/hotel/">호텔·숙소</a>는 객실 호수와 프런트 출입 규정,
        <a href="/service/officetel/">오피스텔</a>은 동·호수와 공동현관 출입
        방법을 미리 확인하면 방문이 원활합니다. 자세한 내용은
        <a href="/guide/before-use/">이용 전 확인사항</a>을 참고하세요.
      </p>

      <h2>예약 가능 시간과 추가 이동비 기준</h2>
      <table class="info-table">
        <tbody>
          <tr><th>상호</th><td>{SITE.name}</td></tr>
          <tr><th>전화예약</th><td><a href={SITE.phoneHref}>{SITE.phone}</a></td></tr>
          <tr><th>운영시간</th><td>{SITE.hours}</td></tr>
          <tr><th>안내 지역</th><td>{g.regionName} 및 인접 생활권</td></tr>
          <tr><th>추가 이동비</th><td>지역·시간대·거리에 따라 예약 시 안내</td></tr>
        </tbody>
      </table>

      <h2>인접 지역 안내</h2>
      <p>{sido.regionName} 내 인접 지역도 함께 확인해 보세요.</p>
      <div class="chip-list">
        {
          neighbors.map((n) => (
            <a class="chip chip--soft" href={`/area/${g.parentSlug}/${n.regionSlug}/`}>{n.regionName}</a>
          ))
        }
        <a class="chip" href={`/area/${g.parentSlug}/`}>{sido.regionName} 전체</a>
      </div>

      <h2>{g.regionName} 페이지 중복 방지 운영 기준</h2>
      <p>
        {g.regionName} 안내는 구·시 전체 생활권을 설명하고, 역 페이지는 역 주변
        생활권을 설명하도록 역할을 나눕니다. 지역명만 바꾼 본문을 만들지 않으며,
        실제 생활권 차이와 인접 지역·역 연결을 중심으로 안내합니다.
      </p>

      <div class="notice notice--warn">
        <div class="notice__title">예약 안내</div>
        <p style="margin:0">
          전화예약 <a href={SITE.phoneHref}>{SITE.phone}</a> · 텔레그램
          <a href={TELEGRAM.reservation} target="_blank" rel="noopener nofollow">문의하기</a>.
          허위 후기·선정적 표현 없이 정보형으로 안내합니다.
        </p>
      </div>

      <h2>{g.regionName} 자주 묻는 질문</h2>
      <div class="faq">
        {
          faq.map((f) => (
            <details>
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
