---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import LocalNav from "../../../components/LocalNav.astro";
import PriceTable from "../../../components/PriceTable.astro";
import { SITE, TELEGRAM, sidoName } from "../../../lib/site";
import {
  sigungus,
  getSido,
  sigungusBySido,
  stations,
  stationsInSigungu,
  dongsOf,
  hasDongDetail,
  isIndexable,
} from "../../../lib/data";
import {
  breadcrumbSchema,
  faqSchema,
  serviceAreaSchema,
} from "../../../lib/seo";

export function getStaticPaths() {
  return sigungus.map((g) => ({
    params: { sido: g.parentSlug, gu: g.regionSlug },
    props: { g },
  }));
}

const { g } = Astro.props;
const sido = getSido(g.parentSlug)!;
const path = `/area/${g.parentSlug}/${g.regionSlug}/`;
const noindex = !isIndexable(g.contentStatus);

// 대표 행정동 (ㄱㄴㄷ 정렬, 번호동 통합). 데이터 없으면 nearbyAreas 폴백
const dongList = dongsOf(g.regionSlug);
const fallbackAreas = g.nearbyAreas.map((a) => ({ name: a, slug: "", blurb: "" }));
const areaList = dongList.length ? dongList : fallbackAreas;

// 본문 보강용 — 행정동 수에 반비례해 분량 조절(2,000~2,500자 유지)
const ns = g.nearbyStations.length ? g.nearbyStations : ["인근 역"];
const pairA0 = areaList[0]?.name ?? g.regionName;
const pairA1 = areaList[1]?.name ?? pairA0;
const pairA2 = areaList[2]?.name ?? pairA1;
const smallList = areaList.length <= 9;

// 역세권: 이 지역 소속 역 + 데이터에 등록된 인접역
const guStations = stationsInSigungu(g.regionSlug);
const stationByName = (name: string) =>
  stations.find((st) => st.stationName === name);

// 인접 지역
const neighbors = sigungusBySido(g.parentSlug)
  .filter((x) => x.regionSlug !== g.regionSlug)
  .slice(0, 8);

const title = `${g.regionName} 출장마사지｜${g.nearbyAreas
  .slice(0, 2)
  .join("·")} 생활권 홈타이 안내`;
const description = `${g.regionName} 출장마사지 예약 전 ${g.nearbyAreas
  .slice(0, 3)
  .join("·")} 인접 생활권을 확인하세요.`;

const faq = [
  {
    q: `${g.regionName} 출장마사지·홈타이는 어떻게 예약하나요?`,
    a: `전화예약 ${SITE.phone} 또는 텔레그램으로 ${g.regionName} 내 방문 위치와 가능 주소, 희망 시간을 알려주시면 방문 가능 생활권과 추가 이동비 기준을 안내드립니다.`,
  },
  {
    q: `${g.regionName} 기본 요금은 어떻게 되나요?`,
    a: `60분 90,000원, 90분 150,000원, 120분 180,000원을 기본으로 안내합니다. 방문 지역·시간대·이동 거리에 따라 최종 금액은 통화 시 확정됩니다.`,
  },
  {
    q: `${g.regionName} 추가 이동비 기준이 궁금합니다.`,
    a: `지역과 시간대, 거리에 따라 추가 이동비가 발생할 수 있습니다. 예약 전 텔레그램 또는 전화로 정확한 기준을 확인하실 수 있습니다.`,
  },
];

const schema = noindex
  ? []
  : [
      breadcrumbSchema([
        { name: "홈", path: "/" },
        { name: "지역 안내", path: "/area/" },
        { name: sido.regionName, path: `/area/${g.parentSlug}/` },
        { name: g.regionName, path },
      ]),
      serviceAreaSchema(`${g.regionName} 출장마사지·홈타이`, path),
      faqSchema(faq),
    ];
---

<BaseLayout
  title={title}
  description={description}
  path={path}
  noindex={noindex}
  schema={schema}
>
  <LocalNav homeLabel={g.regionName} homeHref={path} />
  <Breadcrumbs
    items={[
      { name: "홈", path: "/" },
      { name: "지역 안내", path: "/area/" },
      { name: sido.regionName, path: `/area/${g.parentSlug}/` },
      { name: g.regionName },
    ]}
  />

  <!-- 헤더 -->
  <section class="section" style="padding:8px 0 24px">
    <div class="container prose">
      <span class="eyebrow">{sidoName(g.parentSlug)} · {g.regionName}</span>
      <h1>{g.regionName} 출장마사지 · {g.regionName} 홈타이 지역별 예약 안내</h1>
      <p class="hero__sub" style="color:var(--text-soft)">
        {g.nearbyAreas.join(", ")} 등 {g.regionName} 주요 생활권별 방문 가능
        지역과 예약 전 확인사항을 안내합니다.
      </p>
      <div class="hero__cta" style="margin-top:18px">
        <a class="btn btn--cta" href="#areas">지역별 안내 보기</a>
        <a class="btn btn--blue" href="#stations">가까운 역 찾기</a>
        <a class="btn btn--outline" href="/reservation/">예약 안내</a>
        <a class="btn btn--outline" href="/guide/before-use/">이용 전 확인사항</a>
      </div>
    </div>
  </section>

  <!-- 먼저 확인할 기준 -->
  <section class="section" style="padding-top:0">
    <div class="container prose">
      <h2>{g.regionName}에서 출장마사지를 찾을 때 먼저 확인할 기준</h2>
      <p>
        {g.regionName}에서 출장마사지와 홈타이를 찾을 때는 {g.contentFocus} 점을
        함께 확인하면 좋습니다. {g.regionName}은 생활권마다 상권과 주거지, 오피스텔
        분포가 달라 방문 가능 지역 확인 기준도 조금씩 다릅니다.
        {g.nearbyAreas.slice(0, 3).join(", ")} 등 대표 생활권을 기준으로 가까운
        지하철역과 방문 동선을 함께 확인하면 예약이 수월합니다. 방문
        위치(자택·호텔·오피스텔)와 시간대, 이동 거리에 따라 예약 가능 시간과 추가
        이동비 기준이 달라질 수 있으므로, 예약 전에 정확한 주소와 건물 출입 방식을
        확인하는 방식을 권장합니다.
      </p>
      <p>
        {g.regionName}과 가까운 지하철역으로는 {ns.join(", ")} 등이 있어,
        역세권 생활권과 주거지 생활권의 방문 동선이 다릅니다. 업무지구·오피스텔이
        밀집한 생활권은 평일 예약 수요가 높고, 주거지 중심 생활권은 야간·주말 방문
        가능 여부 확인이 중요합니다.
      </p>
      {
        smallList && (
          <p>
            대표적으로 {pairA0}은(는) {ns[0]} 인근 생활권과, {pairA1}은(는){" "}
            {ns[1 % ns.length]} 인근 생활권과 함께 확인할 수 있습니다. {pairA2} 등
            인접 지역도 같은 {g.regionName} 안에서 생활권별로 방문 가능 지역과 추가
            이동비 기준이 달라질 수 있으므로, 자택·숙소·오피스텔 위치와 희망 시간을
            먼저 정리해 두면 예약이 빠릅니다.
          </p>
        )
      }
    </div>
  </section>

  <!-- 요금표 (메인 + 모든 지역 페이지 공통) -->
  <PriceTable areaLabel={g.regionName} />

  <!-- 지역별 안내 -->
  <section class="section section-anchor" id="areas">
    <div class="container">
      <div class="section__head">
        <span class="eyebrow">지역별 안내</span>
        <h2 class="section__title">{g.regionName} 대표 지역별 방문 가능 지역 안내</h2>
        <p class="section__lead">
          {g.regionName}의 대표 지역(행정동)을 가나다순으로 정리했습니다. 번호
          동은 대표 동으로 통합해 안내합니다.
        </p>
      </div>
      <div class="area-rows">
        {
          areaList.map((d) => {
            const href =
              d.slug && hasDongDetail(g.regionSlug, d.slug)
                ? `/area/${g.parentSlug}/${g.regionSlug}/${d.slug}/`
                : null;
            const Tag = href ? "a" : "div";
            return (
              <Tag class="area-row" href={href} id={d.slug ? `dong-${d.slug}` : undefined}>
                <b>{d.name} {href && <span class="arrow">→</span>}</b>
                <span>
                  {d.blurb ||
                    `${g.regionName} ${d.name} 일대 주거지와 상권을 포함한 생활권입니다. 방문 가능 주소와 건물 출입 가능 여부를 먼저 확인하세요.`}
                </span>
              </Tag>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- 역세권 안내 -->
  <section class="section section--soft section-anchor" id="stations">
    <div class="container">
      <div class="section__head">
        <span class="eyebrow">역세권 안내</span>
        <h2 class="section__title">{g.regionName} 주요 지하철역별 홈타이 안내</h2>
        <p class="section__lead">
          역명 기준으로 하나의 안내 페이지를 제공합니다. 환승역도 노선·출구별로
          나누지 않습니다.
        </p>
      </div>
      {
        guStations.length ? (
          <div class="grid grid--3">
            {guStations.map((st) => (
              <a class="card" href={`/station/${st.stationGroup}/${st.stationSlug}/`}>
                <div class="card__title">{st.stationName} <span class="arrow">→</span></div>
                <p class="card__desc">{st.nearbyAreas.slice(0, 3).join(", ")} 인접 생활권입니다. 방문 주소와 건물 출입 가능 여부를 먼저 확인하세요.</p>
              </a>
            ))}
          </div>
        ) : (
          <p class="muted">역세권 상세 안내는 순차적으로 확장됩니다.</p>
        )
      }
      <div class="chip-list" style="margin-top:16px">
        {
          g.nearbyStations.map((name) => {
            const st = stationByName(name);
            return st ? (
              <a class="chip chip--soft" href={`/station/${st.stationGroup}/${st.stationSlug}/`}>{name}</a>
            ) : (
              <span class="chip chip--soft">{name}</span>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- 생활권 안내 -->
  <section class="section section-anchor" id="life">
    <div class="container">
      <div class="section__head">
        <span class="eyebrow">생활권 안내</span>
        <h2 class="section__title">{g.regionName} 인근 생활권 예약 기준</h2>
        <p class="section__lead">
          생활권 안내는 지역 페이지와 역 페이지 사이를 연결하는 중간 허브입니다.
        </p>
      </div>
      <div class="chip-list">
        {
          sido.lifeAreas.map((l) => (
            <a class="chip" href="/life/">{l}</a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 이용 전 확인사항 -->
  <section class="section section--soft">
    <div class="container prose">
      <h2>{g.regionName} 홈타이 예약 전 확인사항</h2>
      <p>
        {g.regionName} 방문 전 아래 항목을 미리 확인하시면 예약과 방문이
        원활합니다.
      </p>
      <ul>
        <li>방문 가능 주소 확인 (자택·호텔·오피스텔 동·호수)</li>
        <li>예약 가능 시간 확인</li>
        <li>추가 이동비 여부 확인</li>
        <li>건물 출입 방식(공동현관·프런트) 확인</li>
        <li>결제 방식 확인</li>
        <li>예약 변경 기준 확인</li>
        <li>개인정보 처리 기준 확인</li>
        <li>불법·선정적 서비스 불가 안내</li>
      </ul>

      <table class="info-table">
        <tbody>
          <tr><th>상호</th><td>{SITE.name}</td></tr>
          <tr><th>전화예약</th><td><a href={SITE.phoneHref}>{SITE.phone}</a></td></tr>
          <tr><th>운영시간</th><td>{SITE.hours}</td></tr>
          <tr><th>안내 지역</th><td>{g.regionName} 및 인접 생활권</td></tr>
          <tr><th>기본 요금</th><td>60분 90,000원 · 90분 150,000원 · 120분 180,000원</td></tr>
          <tr><th>추가 이동비</th><td>지역·시간대·거리에 따라 예약 시 안내</td></tr>
        </tbody>
      </table>

      <div class="notice notice--warn">
        <div class="notice__title">예약 안내</div>
        <p style="margin:0">
          전화예약 <a href={SITE.phoneHref}>{SITE.phone}</a> · 텔레그램
          <a href={TELEGRAM.reservation} target="_blank" rel="noopener nofollow">문의하기</a>.
          허위 후기·선정적 표현 없이 정보형으로 안내합니다.
        </p>
      </div>

      <h2>인접 지역 안내</h2>
      <p>{sido.regionName} 내 인접 지역도 함께 확인해 보세요.</p>
      <div class="chip-list">
        {
          neighbors.map((n) => (
            <a class="chip chip--soft" href={`/area/${g.parentSlug}/${n.regionSlug}/`}>{n.regionName}</a>
          ))
        }
        <a class="chip" href={`/area/${g.parentSlug}/`}>{sido.regionName} 전체</a>
      </div>

      <h2>{g.regionName} 페이지 중복 방지 운영 기준</h2>
      <p>
        {g.regionName} 안내는 구 전체 생활권을 설명하고, 역 페이지는 역 주변
        생활권을 설명하도록 역할을 나눕니다. 지역명만 바꾼 본문을 만들지 않으며,
        대표 행정동의 실제 생활권 차이와 인접 지역·역 연결을 중심으로 안내합니다.
      </p>

      <h2>{g.regionName} 자주 묻는 질문</h2>
      <div class="faq">
        {
          faq.map((f) => (
            <details>
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
