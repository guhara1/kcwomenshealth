---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { SITE } from "../lib/site";
import { breadcrumbSchema } from "../lib/seo";

const path = "/contact/";
const title = "고객센터｜예약·이용 문의";
const description =
  "VIP 마사지 고객센터. 예약·이용 문의는 전화 0508-202-4719로 연락 주세요.";
const schema = [
  breadcrumbSchema([
    { name: "홈", path: "/" },
    { name: "고객센터", path },
  ]),
];
---

<BaseLayout title={title} description={description} path={path} schema={schema}>
  <Breadcrumbs items={[{ name: "홈", path: "/" }, { name: "고객센터" }]} />
  <section class="section" style="padding-top:8px">
    <div class="container prose">
      <span class="eyebrow">고객센터</span>
      <h1>고객센터 · 문의 안내</h1>
      <p>예약 및 이용 문의는 전화로 연락 주시면 빠르게 안내드립니다.</p>

      <table class="info-table">
        <tbody>
          <tr><th>상호</th><td>{SITE.name}</td></tr>
          <tr><th>전화예약</th><td><a href={SITE.phoneHref}>{SITE.phone}</a></td></tr>
          <tr><th>운영시간</th><td>{SITE.hours}</td></tr>
          <tr><th>안내 지역</th><td>서울 · 경기 · 인천 · 부산</td></tr>
        </tbody>
      </table>

      <div class="hero__cta">
        <a class="btn btn--cta" href={SITE.phoneHref}>전화예약 {SITE.phone}</a>
        <a class="btn btn--outline" href="/reservation/">예약 안내 보기</a>
      </div>

      <p class="muted" style="margin-top:20px">
        ※ 웹사이트 제작·광고 문의는 페이지 하단(푸터)의 텔레그램 버튼을 이용해
        주세요.
      </p>
    </div>
  </section>
</BaseLayout>
