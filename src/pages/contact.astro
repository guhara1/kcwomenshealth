---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { SITE, TELEGRAM } from "../lib/site";
import { breadcrumbSchema } from "../lib/seo";

const path = "/contact/";
const title = "고객센터｜예약·제휴·웹사이트 제작 문의";
const description =
  "VIP 마사지 고객센터. 전화예약과 텔레그램으로 예약·제휴·웹사이트 제작 문의를 받습니다.";
const schema = [
  breadcrumbSchema([
    { name: "홈", path: "/" },
    { name: "고객센터", path },
  ]),
];
---

<BaseLayout title={title} description={description} path={path} schema={schema}>
  <Breadcrumbs items={[{ name: "홈", path: "/" }, { name: "고객센터" }]} />
  <section class="section" style="padding-top:8px">
    <div class="container prose">
      <span class="eyebrow">고객센터</span>
      <h1>고객센터 · 문의 안내</h1>
      <p>예약, 제휴, 웹사이트 제작 문의를 아래 채널로 받습니다.</p>

      <table class="info-table">
        <tbody>
          <tr><th>상호</th><td>{SITE.name}</td></tr>
          <tr><th>전화예약</th><td><a href={SITE.phoneHref}>{SITE.phone}</a></td></tr>
          <tr><th>운영시간</th><td>{SITE.hours}</td></tr>
          <tr><th>예약 문의</th><td><a href={TELEGRAM.reservation} target="_blank" rel="noopener nofollow">텔레그램 예약</a></td></tr>
          <tr><th>웹사이트 제작</th><td><a href={TELEGRAM.webBuild} target="_blank" rel="noopener nofollow">텔레그램 제작문의</a></td></tr>
          <tr><th>제휴 문의</th><td><a href={TELEGRAM.partnership} target="_blank" rel="noopener nofollow">텔레그램 제휴문의</a></td></tr>
        </tbody>
      </table>

      <div class="hero__cta">
        <a class="btn btn--cta" href={TELEGRAM.webBuild} target="_blank" rel="noopener nofollow">웹사이트 제작문의</a>
        <a class="btn btn--cta" href={TELEGRAM.partnership} target="_blank" rel="noopener nofollow">제휴문의</a>
        <a class="btn btn--blue" href={SITE.phoneHref}>전화예약 {SITE.phone}</a>
      </div>
    </div>
  </section>
</BaseLayout>
